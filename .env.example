# Local dev environment — copy to .env and fill in provider keys as needed.
# Real .env files are gitignored.

# --- Postgres (used by docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=benchmarks

# DATABASE_URL is set automatically inside docker-compose for the api/runner/migrate
# services. If you run `coval-bench` directly on the host, point it at the compose db:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/benchmarks

# --- Runner / dataset ---
DATASET_BUCKET=coval-benchmarks-datasets
DATASET_ID=stt-v2
RUNNER_SHA=local
LOG_LEVEL=INFO

# --- Provider API keys (optional; only needed for the providers you want to exercise) ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
SPEECHMATICS_API_KEY=
HUME_API_KEY=
RIME_API_KEY=
GLADIA_API_KEY=
GRADIUM_API_KEY=
GRADIUM_TTS_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
SMALLEST_API_KEY=
SONIOX_API_KEY=
REVAI_API_KEY=
FISHAUDIO_API_KEY=

# --- Google STT/TTS (optional; requires the `google-stt` / `google-tts` extras) ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_PROJECT_ID=

# --- Azure AI Speech STT + TTS (subscription key + region of the Speech resource) ---
# AZURE_API_KEY=
# AZURE_REGION=eastus
