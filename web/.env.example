# Used by the leaderboard and results pages to fetch benchmark data.
# Not used by the playground — playground routes call providers directly via Vercel env vars below.
NEXT_PUBLIC_API_URL=http://localhost:8000
# ---------------------------------------------------------------------------
# PostHog analytics
# Add real values locally and in Vercel before enabling event capture.
# Optional local debug: set to `true` or append `?posthog_debug=1` to a URL
# to log captured PostHog events in the browser console.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Intentionally disabled; set to true to log PostHog events in the browser console.
NEXT_PUBLIC_POSTHOG_DEBUG=false
# ---------------------------------------------------------------------------
# Playground — Vercel server-side only (no NEXT_PUBLIC_ prefix)
# Set in Vercel → Settings → Environment Variables.
# Read by Vercel Route Handlers. Never returned to the browser.
# ---------------------------------------------------------------------------
# TTS
PLAYGROUND_ELEVENLABS_API_KEY=
PLAYGROUND_CARTESIA_API_KEY=
PLAYGROUND_DEEPGRAM_API_KEY=
PLAYGROUND_RIME_API_KEY=
# STT
PLAYGROUND_ASSEMBLYAI_API_KEY=
PLAYGROUND_SPEECHMATICS_API_KEY=
